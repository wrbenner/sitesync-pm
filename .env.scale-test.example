# =============================================================================
# .env.scale-test.example  —  copy to .env.scale-test and fill in real values.
#
# The runbook expects: `set -a; source .env.scale-test; set +a`
# .env.scale-test is gitignored. Never commit real values.
#
# CRITICAL: Point at staging, NOT production. The SCALE_TEST_PROD_BLOCKLIST
# guard refuses runs against listed hosts as a belt-and-suspenders backstop.
# =============================================================================

# Staging Supabase project URL (e.g. https://abcd1234.supabase.co)
SUPABASE_URL=https://<staging-project-ref>.supabase.co

# Staging service-role key — full admin access. Required by seed-orgs.ts +
# seed-storage.ts to create auth.users and bypass RLS for fixture rows.
SUPABASE_SERVICE_KEY=<staging-service-role-key>

# Staging anon key — used by mint-vu-tokens.ts (signInWithPassword) and by k6
# as the `apikey` header. The k6 Authorization header uses real per-VU JWTs.
SUPABASE_ANON_KEY=<staging-anon-key>

# Shared password used for ALL seeded users. Pick a fresh random value per
# battle-test cycle so a leaked password from a prior run doesn't have access.
# Generated example: 790iFHUJ9obf1QgHqXjfpQ9PFVxFebsw
SCALE_TEST_PASSWORD=<random-32-char-string>

# Comma-separated list of production project refs that the seed + run scripts
# must refuse to execute against. The host check matches on substring against
# the resolved SUPABASE_URL host. Add every prod ref you have, never blank.
# Example: SCALE_TEST_PROD_BLOCKLIST=hypxrmcppjfbtlwuoafc,yuveewurqbibnqkfthbd
SCALE_TEST_PROD_BLOCKLIST=<comma-separated-prod-project-refs>

# Owner email used by the CRUD round-trip Playwright spec (06-crud-roundtrip).
# Must be one of the emails emitted by seed-orgs.ts NDJSON output, e.g.
# scaletest-org-001-owner@sitesync.test
SCALE_TEST_OWNER_EMAIL=scaletest-org-001-owner@sitesync.test
