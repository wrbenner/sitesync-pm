---
import BaseLayout from '~/layouts/BaseLayout.astro';

const includes = [
  'Unlimited projects',
  'Unlimited users',
  'AI Copilot included',
  '100 GB storage',
  'Audit-grade hash-chained log',
  'SSO + API access',
  'Email + in-app support',
  'PWA + (soon) native iOS app',
];

const faqs = [
  { q: 'Why one tier?',
    a: 'Pricing transparency is a feature. Most construction software hides the price; we don\'t. One tier means no upgrade traps and no "request a quote" friction.' },
  { q: 'What\'s included in the AI Copilot?',
    a: 'AI-drafted RFIs, submittals, daily logs, and follow-up tasks. Every draft is hash-chained and audit-logged. You always approve before anything goes anywhere.' },
  { q: 'Can I switch from monthly to annual later?',
    a: 'Yes. Use the in-app billing portal at any time. Stripe prorates the difference automatically.' },
  { q: 'What\'s the refund policy?',
    a: 'Cancel any time during the 14-day trial — no charge. After that, monthly cancels take effect at period end. Annual prepay is non-refundable but you keep access through the prepaid year.' },
  { q: 'What happens after the trial?',
    a: 'On day 14 we charge the card on file. If the charge fails we\'ll email you, retry, and pause read-only on day 8 of failure — never a silent suspension.' },
];

const competitors = [
  { name: 'Procore', price: '$25,000+/yr', owns: 'Enterprise GCs, RFI workflow', gap: 'Mobile is desktop-ported. Opaque pricing. Months to learn.' },
  { name: 'Buildertrend', price: '$3,600/yr', owns: 'Residential CRM-to-invoice', gap: 'No commercial workflows. No AI. Weak mobile.' },
  { name: 'Fieldwire', price: 'Per-user', owns: 'True mobile-first, plan markup', gap: 'No financial tools. No AI. No portfolio view.' },
  { name: 'SiteSync', price: '$400/mo', owns: 'Mobile + AI + audit + sub-friendly', gap: '— this is us —' },
];
---
<BaseLayout
  title="Pricing — SiteSync"
  description="One tier. $400/month per company. 14-day trial, card required, cancel anytime."
>
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-12 text-center">
    <h1 class="font-display text-4xl font-bold tracking-tight text-brand-ink">
      Pricing built for construction, not vendors.
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-brand-mute">
      One tier. Clear price. Card-on-file 14-day trial. No "request a quote."
    </p>
  </section>

  <!-- PRICING CARD -->
  <section class="mx-auto max-w-md px-6 pb-12">
    <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
      <div class="text-sm font-semibold uppercase tracking-wide text-brand-accent">SiteSync Pro</div>
      <div class="mt-3 flex items-baseline">
        <span class="text-5xl font-bold text-brand-ink">$400</span>
        <span class="ml-2 text-base text-brand-mute">/month per company</span>
      </div>
      <div class="mt-2 text-sm text-brand-mute">
        Annual prepay $4,080/yr (15% off)
      </div>
      <a href="https://app.sitesyncai.com/signup"
         class="mt-6 block w-full rounded-md bg-brand-accent px-6 py-3 text-center text-base font-semibold text-white hover:bg-blue-600">
        Start 14-day trial
      </a>
      <ul class="mt-6 space-y-2 text-sm text-brand-ink">
        {includes.map((i) => (
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-brand-accent" aria-hidden="true">✓</span>
            <span>{i}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- COMPETITORS TABLE -->
  <section class="mx-auto max-w-6xl px-6 py-12">
    <h2 class="font-display text-2xl font-bold text-brand-ink">How we compare</h2>
    <div class="mt-6 overflow-x-auto">
      <table class="min-w-full text-left text-sm">
        <thead>
          <tr class="border-b border-slate-200 text-brand-mute">
            <th class="py-3 pr-4 font-semibold">Tool</th>
            <th class="py-3 pr-4 font-semibold">Price</th>
            <th class="py-3 pr-4 font-semibold">Owns</th>
            <th class="py-3 pr-4 font-semibold">Where they leave room</th>
          </tr>
        </thead>
        <tbody>
          {competitors.map((c) => (
            <tr class="border-b border-slate-100 align-top">
              <td class="py-4 pr-4 font-semibold text-brand-ink">{c.name}</td>
              <td class="py-4 pr-4 text-brand-ink">{c.price}</td>
              <td class="py-4 pr-4 text-brand-mute">{c.owns}</td>
              <td class="py-4 pr-4 text-brand-mute">{c.gap}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-display text-2xl font-bold text-brand-ink">Frequently asked</h2>
    <div class="mt-6 space-y-6">
      {faqs.map((f) => (
        <div>
          <h3 class="font-semibold text-brand-ink">{f.q}</h3>
          <p class="mt-1 text-brand-mute">{f.a}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
