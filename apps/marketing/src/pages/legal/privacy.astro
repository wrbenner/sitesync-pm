---
import BaseLayout from '~/layouts/BaseLayout.astro';
---
<BaseLayout
  title="Privacy Policy — SiteSync"
  description="SiteSync Privacy Policy."
  noIndex={true}
>
  <article class="mx-auto max-w-prose px-6 pt-24 pb-12 text-brand-ink">
    <h1 class="font-display text-3xl font-bold">Privacy Policy</h1>
    <p class="mt-2 text-sm text-brand-mute">Effective date: pending counsel review</p>

    <div class="mt-8 rounded-md border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
      <strong>Placeholder.</strong> Counsel-drafted Privacy Policy will replace
      this content before public launch. SiteSync does not sell your data.
      AI providers (Anthropic, OpenAI, Perplexity, Gemini) process data per
      call only; we are subject to their respective DPAs and our subprocessor
      list will be published here at launch.
    </div>
  </article>
</BaseLayout>
