<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  iOS Universal-Link / URL-scheme manifest snippet.

  Drop the contents of `<key>CFBundleURLTypes</key>` block into the iOS
  app's Info.plist (under ios/App/App/Info.plist after `npx cap sync ios`).
  The Capacitor sync overwrites Info.plist on every build; preserve this
  block manually OR define it in the Capacitor config.

  Schema: sitesync://...
  Routes are parsed by src/lib/native/deepLink.ts.
-->
<plist version="1.0">
  <dict>
    <key>CFBundleURLTypes</key>
    <array>
      <dict>
        <key>CFBundleURLName</key>
        <string>com.sitesync.app.deeplink</string>
        <key>CFBundleURLSchemes</key>
        <array>
          <string>sitesync</string>
        </array>
        <key>CFBundleTypeRole</key>
        <string>Editor</string>
      </dict>
    </array>

    <!-- Universal-Link (https://app.sitesync.example/share/...) — used by
         magic-link share emails when the user has the app installed. -->
    <key>com.apple.developer.associated-domains</key>
    <array>
      <string>applinks:app.sitesync.example</string>
    </array>

    <!-- App shortcuts: long-press the icon to surface "New RFI",
         "Capture photo", "Today's daily log". The dynamic counterpart
         lives at runtime via the Capacitor App plugin (see push.ts). -->
    <key>UIApplicationShortcutItems</key>
    <array>
      <dict>
        <key>UIApplicationShortcutItemType</key>
        <string>com.sitesync.app.new_rfi</string>
        <key>UIApplicationShortcutItemTitle</key>
        <string>New RFI</string>
        <key>UIApplicationShortcutItemSubtitle</key>
        <string>Draft an RFI immediately</string>
        <key>UIApplicationShortcutItemIconType</key>
        <string>UIApplicationShortcutIconTypeAdd</string>
        <key>UIApplicationShortcutItemUserInfo</key>
        <dict>
          <key>deep_link</key>
          <string>sitesync://capture?intent=rfi</string>
        </dict>
      </dict>
      <dict>
        <key>UIApplicationShortcutItemType</key>
        <string>com.sitesync.app.capture_photo</string>
        <key>UIApplicationShortcutItemTitle</key>
        <string>Capture photo</string>
        <key>UIApplicationShortcutItemIconType</key>
        <string>UIApplicationShortcutIconTypeCapturePhoto</string>
        <key>UIApplicationShortcutItemUserInfo</key>
        <dict>
          <key>deep_link</key>
          <string>sitesync://capture</string>
        </dict>
      </dict>
      <dict>
        <key>UIApplicationShortcutItemType</key>
        <string>com.sitesync.app.todays_log</string>
        <key>UIApplicationShortcutItemTitle</key>
        <string>Today&#39;s daily log</string>
        <key>UIApplicationShortcutItemIconType</key>
        <string>UIApplicationShortcutIconTypeCompose</string>
        <key>UIApplicationShortcutItemUserInfo</key>
        <dict>
          <key>deep_link</key>
          <string>sitesync://daily-log</string>
        </dict>
      </dict>
    </array>
  </dict>
</plist>
