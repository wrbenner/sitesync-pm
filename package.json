    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "perfect-freehand": "^1.2.3",
    "playwright": "^1.60.0",
    "posthog-js": "^1.373.1",
    "react": "^19.2.6",
    "react-big-calendar": "^1.19.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.6",
    "react-grid-layout": "^2.2.3",
    "react-i18next": "^17.0.7",
    "react-leaflet": "^4.2.1",
    "react-pdf": "^10.4.1",
    "react-qr-code": "^2.0.21",
    "react-router-dom": "^7.15.0",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "three": "^0.184.0",
    "web-ifc": "^0.0.77",
    "wx-react-gantt": "^1.3.1",
    "xlsx": "^0.18.5",
    "xstate": "^5.31.1",
    "yjs": "^13.6.30",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
