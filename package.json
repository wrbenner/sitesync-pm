{
  "name": "sitesync-pm",
  "private": true,
  "version": "1.0.0-alpha.1",
  "type": "module",
  "sideEffects": [
    "*.css",
    "./src/lib/i18n.ts",
    "./src/lib/sentry.ts"
  ],
  "engines": {
    "node": "^22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "db-types:check": "tsx scripts/check-db-types.ts",
    "db-types:write": "tsx scripts/check-db-types.ts --write",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:acceptance": "playwright test --config=playwright.acceptance.config.ts",
    "test:coverage": "vitest run --coverage",
    "audit": "npm run audit:gen && npm run audit:static && playwright test audit/generated audit/harness/route-audit.ts",
    "iris:eval:persona": "tsx tests/iris-evals/persona-divergence/run.ts",
    "iris-eval-kb-retrieval": "tsx tests/iris-evals/kb-retrieval/run.ts",
    "audit:static": "tsx scripts/audit.ts",
    "audit:gen": "tsx scripts/generate-e2e.ts",
    "bundle:check": "node scripts/check-bundle-size.js",
    "validate:rfi-audit": "node scripts/validate-rfi-audit-coverage.mjs",
    "lint:rfi-voice": "tsx scripts/lint-rfi-voice.ts",
    "permissions:generate": "tsx scripts/generate-permissions-sql.ts",
    "permissions:check": "tsx scripts/check-permissions-sync.ts",
    "build:analyze": "ANALYZE=true vite build",
    "cap:build:ios": "npm run build && npx cap sync ios",
    "cap:build:android": "npm run build && npx cap sync android",
    "seed:demo-account": "tsx scripts/seed-demo-account.ts",
    "seed:iris-inbox": "tsx scripts/seed-iris-inbox.ts",
    "demo:refresh": "tsx scripts/demo-refresh.ts",
    "demo:refresh:dry": "tsx scripts/demo-refresh.ts --dry-run",
    "eval:iris": "tsx evals/iris/run-iris-eval.ts",
    "eval:iris:ci": "tsx evals/iris/run-iris-eval.ts && tsx scripts/check-iris-eval.ts",
    "eval:iris:expand": "tsx scripts/build-iris-corpus.ts",
    "doctor": "tsx scripts/doctor.ts",
    "doctor:fix": "tsx scripts/doctor.ts --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
