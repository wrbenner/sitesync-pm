# macOS Finder / iCloud sync conflict duplicates ("foo 2.tsx", "foo 3.md", etc.)
# These regenerate constantly when iCloud Drive resolves a conflict.
# They are never source — always identical to the un-suffixed file.
# Any single-digit numeric suffix is iCloud, regardless of extension, and may
# also appear on directories ("android/app 4/") or extension-less files.
*\ [0-9].*
*\ [0-9]/
*\ [0-9]
polish-review/

# Playwright auth-setup state — contains live session tokens, never commit.
playwright/.auth/
.auth/

# Capacitor / Xcode build & user-specific artifacts (committed: ios/ project itself).
ios/App/Pods/
ios/App/build/
ios/App/DerivedData/
ios/App/output/
ios/App/Podfile.lock
ios/App/*.xcworkspace/xcuserdata/
ios/App/*.xcodeproj/xcuserdata/
ios/App/*.xcodeproj/project.xcworkspace/xcuserdata/
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/app/release/

# iOS signing material — NEVER commit. Live secrets are in GitHub Actions
# secrets (APP_STORE_CONNECT_API_KEY_*, APPLE_TEAM_ID, APP_BUNDLE_ID).
secrets/
*.p8
*.mobileprovision
*.cer
*.p12

# Fastlane transient output
fastlane/report.xml
fastlane/test_output/
fastlane/build/
fastlane/.env*
