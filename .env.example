VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_LIVEBLOCKS_PUBLIC_KEY=
VITE_LIVEBLOCKS_AUTH_ENDPOINT=
ANTHROPIC_API_KEY=
LIVEBLOCKS_SECRET_KEY=
RESEND_API_KEY=
# BRT sub-6 §4.1 — Crisp chat embed. Get website ID from app.crisp.chat → Settings → Setup
VITE_CRISP_WEBSITE_ID=
# Set to "true" to load Crisp in dev (default off so dev sessions don't pollute support)
VITE_CRISP_FORCE_DEV=

# ─────────────────────────────────────────────────────────────────────────────
# Feature flags — compile-time gates for unfinished/stub routes.
# All default to false (OFF) in production. Set to "true" in .env.local to
# enable while developing. Never commit .env.local.
#
# See src/lib/featureFlags.ts for the full registry.
# Eleven Never #9: placeholder routes must be hidden by flag, gated, or removed.
# ─────────────────────────────────────────────────────────────────────────────
VITE_FLAG_BIM_VIEWER=false
VITE_FLAG_IRIS_INBOX=false
VITE_FLAG_APPROVAL_WORKFLOWS=false
VITE_FLAG_OWNER_REPORT=false
VITE_FLAG_SPEC_PARSER=false
VITE_FLAG_PROCORE_IMPORT=false
VITE_FLAG_PROJECT_TEMPLATES=false
VITE_FLAG_BULK_INVITE=false
VITE_FLAG_WALKTHROUGH=false
VITE_FLAG_COMPLIANCE_COCKPIT=false
